# Modal app identity
POCKET_TTS_MODAL_APP=pocket-tts

# Volumes
MODEL_VOLUME_NAME=pocket-tts-models
# Optional: mount a voices volume at /voices
VOICES_VOLUME_NAME=pocket-tts-voices

# Optional: Modal secret name containing AUTHENTICATION_ALLOWED_TOKENS
AUTH_SECRET_NAME=pocket-tts-auth

# Optional: Modal secret name containing HF_TOKEN
# HF_SECRET_NAME=pocket-tts-hf

# Optional: source path to sync voices into the voices volume
# POCKET_TTS_VOICES_SRC=/app/voices

# Optional: force a specific model path or variant
# POCKET_TTS_MODEL_PATH=

# Optional: override voices directory in the container
# POCKET_TTS_VOICES_DIR=

# Observability
POCKET_TTS_COLDSTART_LOG=true
POCKET_TTS_REQUEST_TIMING_LOG=true
POCKET_TTS_REQUEST_TIMING_LOG_JSON=true
POCKET_TTS_TTFA_LOG=true

# Optional: disable the web UI at /
POCKET_TTS_UI_ENABLED=false

# Optional: avoid torch.inference_mode issues in some Pocket-TTS builds
POCKET_TTS_DISABLE_INFERENCE_MODE=true

# Optional: force HuggingFace offline mode when model is cached locally
POCKET_TTS_HF_OFFLINE=true

# Optional: snapshot warmup inference (empty disables)
POCKET_TTS_WARMUP_TEXT=Hello
POCKET_TTS_WARMUP_VOICE=alba

# Limits / headers
POCKET_TTS_MAX_INPUT_CHARS=5000
POCKET_TTS_REQUEST_ID_HEADER=X-Request-ID

# Torch threading (tune per CPU)
POCKET_TTS_TORCH_THREADS=2
POCKET_TTS_TORCH_INTEROP_THREADS=1

# Chunk long inputs into smaller segments (chars). 0 disables chunking.
POCKET_TTS_CHUNK_CHARS=250
# Allow per-request override of chunk size via JSON body (chunk_chars).
POCKET_TTS_CHUNK_CHARS_ALLOW_OVERRIDE=true

# Optional: comma-separated tokens for Bearer auth (local/dev only)
# Note: for Modal deployments, use AUTH_SECRET_NAME instead.
# AUTHENTICATION_ALLOWED_TOKENS=token1,token2
